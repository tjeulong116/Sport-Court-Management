<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>Đặt sân cầu lông</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600&family=Raleway:wght@600;800&display=swap"
        rel="stylesheet">

    <!-- Icons -->
    <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.15.4/css/all.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Client CSS -->
    <link href="/client/css/bootstrap.min.css" rel="stylesheet">
    <link href="/client/css/style.css" rel="stylesheet">

    <style>
        /* =============================
           BOOKING UI
        ============================== */

        .booking-box {
            background: #fff;
            border-radius: 12px;
            padding: 25px;
            box-shadow: 0 0 25px rgba(0, 0, 0, .05);
        }

        .booking-grid {
            overflow-x: auto;
        }

        table.booking-table {
            min-width: 1400px;
        }

        /* RESET bootstrap */
        table.booking-table td {
            background-color: transparent !important;
        }

        td.slot {
            width: 90px;
            height: 60px;
            text-align: center;
            font-size: 12px;
            vertical-align: middle;
            cursor: pointer;
            border-radius: 6px;
            transition: all .15s ease;
        }

        .slot small {
            display: block;
            font-size: 11px;
            opacity: .85;
        }

        /* AVAILABLE */
        table.booking-table td.slot-AVAILABLE {
            background-color: #f8f9fa !important;
            color: #000 !important;
        }

        table.booking-table td.slot-AVAILABLE:hover {
            background-color: #e7f1ff !important;
        }

        /* PAST */
        table.booking-table td.slot-PAST {
            background-color: #e0e0e0 !important;
            color: #888 !important;
            cursor: not-allowed !important;
        }

        /* BOOKED */
        table.booking-table td.slot-BOOKED {
            background-color: #f8d7da !important;
            color: #721c24 !important;
            cursor: not-allowed !important;
            font-weight: 600 !important;
        }

        /* SELECTED */
        table.booking-table td.slot-SELECTED {
            background-color: #0d6efd !important;
            color: #fff !important;
            font-weight: 700 !important;
        }

        .summary-box {
            background: #f8f9fa;
            border-radius: 10px;
            padding: 20px;
        }
    </style>
</head>

<body>

    <!-- Spinner -->
    <div id="spinner"
        class="show w-100 vh-100 bg-white position-fixed translate-middle top-50 start-50 d-flex align-items-center justify-content-center">
        <div class="spinner-grow text-primary"></div>
    </div>

    <!-- Header -->
    <%- include('../layout/header'); -%>

        <!-- Banner -->
        <%- include('../layout/banner'); -%>

            <!-- Booking Section -->
            <div class="container py-5">
                <div class="booking-box">

                    <div class="row mb-4">
                        <div class="col-lg-6">
                            <h2 class="fw-bold text-primary">🏸 Đặt sân cầu lông</h2>
                            <p class="text-muted mb-0">
                                Thứ 2–6: <strong>50.000₫</strong> / 30 phút ·
                                Thứ 7–CN: <strong>70.000₫</strong> / 30 phút
                            </p>
                        </div>
                        <div class="col-lg-6 text-lg-end mt-3 mt-lg-0">
                            <input id="bookingDate" type="date" value="<%= date %>"
                                class="form-control d-inline-block w-auto" onchange="loadGrid()">
                        </div>
                    </div>

                    <!-- GRID -->
                    <div class="booking-grid mb-4">
                        <table class="table table-bordered booking-table">
                            <thead class="table-light">
                                <tr>
                                    <th>Sân / Giờ</th>
                                </tr>
                            </thead>
                            <tbody id="gridBody"></tbody>
                        </table>
                    </div>

                    <!-- SUMMARY -->
                    <div class="row">
                        <div class="col-lg-4 ms-auto">
                            <div class="summary-box">
                                <h5>🧾 Thông tin đặt sân</h5>
                                <p>Số khung giờ: <strong id="slotCount">0</strong></p>
                                <p class="fs-5">
                                    Tổng tiền:
                                    <strong class="text-primary" id="totalPrice">0 ₫</strong>
                                </p>
                                <button id="btnBook" class="btn btn-primary w-100">
                                    <i class="fas fa-calendar-check me-2"></i>
                                    Xác nhận đặt sân
                                </button>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <!-- Footer -->
            <%- include('../layout/footer'); -%>

                <!-- Back to Top -->
                <a href="#" class="btn btn-primary rounded-circle back-to-top">
                    <i class="fa fa-arrow-up"></i>
                </a>

                <!-- JS -->
                <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.4/jquery.min.js"></script>
                <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
                <script src="/client/js/main.js"></script>

                <script>
                    let selectedSlots = []; // { courtId, time, price }

                    function isWeekend(dateStr) {
                        const d = new Date(dateStr);
                        return d.getDay() === 0 || d.getDay() === 6;
                    }

                    function slotPrice(dateStr) {
                        return isWeekend(dateStr) ? 70000 : 50000;
                    }

                    async function loadGrid() {
                        selectedSlots = [];
                        updateSummary();

                        const date = document.getElementById("bookingDate").value;
                        const res = await fetch(`/api/booking/grid?date=${date}`);
                        const grid = await res.json();

                        renderGrid(grid, date);
                    }

                    function renderGrid(grid, date) {
                        const tbody = document.getElementById("gridBody");
                        tbody.innerHTML = "";

                        if (!grid.length) return;

                        const thead = document.querySelector("thead tr");
                        thead.innerHTML = "<th>Sân / Giờ</th>";
                        grid[0].slots.forEach(s => {
                            thead.innerHTML += `<th>${s.time}</th>`;
                        });

                        const price = slotPrice(date);

                        grid.forEach(court => {
                            const tr = document.createElement("tr");
                            tr.innerHTML = `<th>${court.courtName}</th>`;

                            court.slots.forEach(slot => {
                                const td = document.createElement("td");
                                td.className = `slot slot-${slot.status}`;
                                td.innerHTML = `${slot.time}<small>${price.toLocaleString("vi-VN")} ₫</small>`;

                                if (slot.status === "AVAILABLE") {
                                    td.dataset.court = court.courtId;
                                    td.dataset.time = slot.time;
                                    td.dataset.price = price;
                                    td.onclick = () => toggleSlot(td);
                                }

                                tr.appendChild(td);
                            });

                            tbody.appendChild(tr);
                        });
                    }

                    function toggleSlot(td) {
                        const courtId = Number(td.dataset.court);
                        const time = td.dataset.time;
                        const price = Number(td.dataset.price);

                        const idx = selectedSlots.findIndex(
                            s => s.courtId === courtId && s.time === time
                        );

                        if (idx >= 0) {
                            selectedSlots.splice(idx, 1);
                            td.classList.remove("slot-SELECTED");
                        } else {
                            selectedSlots.push({ courtId, time, price });
                            td.classList.add("slot-SELECTED");
                        }

                        updateSummary();
                    }

                    function updateSummary() {
                        const total = selectedSlots.reduce((s, x) => s + x.price, 0);
                        document.getElementById("slotCount").innerText = selectedSlots.length;
                        document.getElementById("totalPrice").innerText =
                            total.toLocaleString("vi-VN") + " ₫";
                    }

                    document.getElementById("btnBook").onclick = async () => {
                        if (!selectedSlots.length) {
                            alert("Vui lòng chọn ít nhất 1 khung giờ");
                            return;
                        }

                        const date = document.getElementById("bookingDate").value;

                        const grouped = {};
                        selectedSlots.forEach(s => {
                            if (!grouped[s.courtId]) grouped[s.courtId] = [];
                            grouped[s.courtId].push(s.time);
                        });

                        for (const courtId in grouped) {
                            await fetch("/api/booking", {
                                method: "POST",
                                headers: { "Content-Type": "application/json" },
                                body: JSON.stringify({
                                    courtId: Number(courtId),
                                    date,
                                    startTimes: grouped[courtId],
                                    status: "PAID",
                                    price: slotPrice(date)
                                })
                            });
                        }

                        alert("🎉 Đặt sân thành công!");
                        loadGrid();
                    };

                    loadGrid();
                </script>

</body>

</html>