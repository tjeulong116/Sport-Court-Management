<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="description" content="Hieubk - Dự án Sportshop" />
    <meta name="author" content="Hieubk" />
    <title>Create Products - Hieubk</title>
    <link href="/admin/css/styles.css" rel="stylesheet" />
    <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script>
        $(document).ready(() => {
            const avatarFile = $("#avatarFile");
            avatarFile.change(function (e) {
                const imgURL = URL.createObjectURL(e.target.files[0]);
                $("#avatarPreview").attr("src", imgURL);
                $("#avatarPreview").css({ "display": "block" });
            });
        });
    </script>
</head>

<body class="sb-nav-fixed">
    <%- include('../layout/header'); -%>

        <div id="layoutSidenav">
            <%- include('../layout/sidenav'); -%>
                <div id="layoutSidenav_content">
                    <main>
                        <div class="container-fluid px-4">
                            <h1 class="mt-4">Manage Products</h1>
                            <ol class="breadcrumb mb-4">
                                <li class="breadcrumb-item"><a href="/admin">Dashboard</a></li>
                                <li class="breadcrumb-item active"><a href="/admin/product">Products</a></li>
                            </ol>
                            <div class="row">
                                <div class="col-6 mx-auto">
                                    <div>
                                        <h5 style="padding: 10px 0">View detail a product:</h5>
                                        <form action="/admin/update-product" method="post"
                                            enctype="multipart/form-data">
                                            <input value="<%= product.id %>" name="id" type="text"
                                                style="display: none;">
                                            <div class="row">
                                                <div class="mb-3 col-6">
                                                    <label class="form-label">Name</label>
                                                    <input value="<%= product.name %>" type="text" class="form-control"
                                                        name="name">
                                                </div>
                                                <div class="mb-3 col-6">
                                                    <label class="form-label">Price</label>
                                                    <input value="<%= product.price %>" type="text" class="form-control"
                                                        name="price">
                                                </div>
                                            </div>
                                            <div class="mb-3">
                                                <label class="form-label">Detail description</label>
                                                <textarea name="detailDesc" class="form-control"
                                                    rows="2"><%= product.detailDesc %></textarea>
                                            </div>

                                            <div class="row">
                                                <div class="mb-3 col-6">
                                                    <label class="form-label">Short Description</label>
                                                    <input value="<%= product.shortDesc %>" type="text"
                                                        class="form-control" name="shortDesc">
                                                </div>
                                                <div class="mb-3 col-6">
                                                    <label class="form-label">Quantity</label>
                                                    <input value="<%= product.quantity %>" type="text"
                                                        class="form-control" name="quantity">
                                                </div>
                                            </div>

                                            <div class="row">
                                                <div class="mb-3 col-6">
                                                    <label class="form-label">Brand</label>
                                                    <select name="brand" class="form-select">
                                                        <% brandOptions.forEach((brand,index)=> { %>
                                                            <option value="<%=brand.value %>"
                                                                <%=brand.value===product.brand ? 'selected' : '' %>
                                                                >
                                                                <%- brand.name %>
                                                            </option>
                                                            <%})%>
                                                    </select>
                                                </div>
                                                <div class="mb-3 col-6">
                                                    <label class="form-label">Level</label>
                                                    <select name="level" class="form-select">
                                                        <% levelOptions.forEach((level,index)=> { %>
                                                            <option value="<%=level.value %>"
                                                                <%=level.value===product.level ? 'selected' : '' %>
                                                                >
                                                                <%- level.name %>
                                                            </option>
                                                            <%})%>
                                                    </select>
                                                </div>
                                            </div>


                                            <div class="mb-3">
                                                <label for="formFile" class="form-label">Image</label>
                                                <input name="image" class="form-control" type="file" id="avatarFile"
                                                    accept=".png, .jpg, .jpeg">
                                            </div>
                                            <% if (product.image) { %>
                                                <img style="max-height: 250px; display: block;" alt="avatar preview"
                                                    id="avatarPreview" src="/images/product/<%=product.image%>" />
                                                <% } else { %>
                                                    <img style="max-height: 250px; display: none;" alt="avatar preview"
                                                        id="avatarPreview" />
                                                    <% } %>
                                                        <div class="mb-3">
                                                            <button type="submit"
                                                                class="btn btn-warning">Submit</button>
                                                        </div>
                                        </form>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </main>
                    <%- include('../layout/footer'); -%>
                </div>
        </div>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"
            crossorigin="anonymous"></script>
        <script src="/admin/js/scripts.js"></script>
</body>

</html>