<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>Manage Bookings</title>

    <link href="/admin/css/styles.css" rel="stylesheet" />
    <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>

    <style>
        .booking-grid {
            overflow-x: auto;
            white-space: nowrap;
        }

        td.slot {
            width: 90px;
            height: 55px;
            text-align: center;
            vertical-align: middle;
            font-size: 12px;
            padding: 4px !important;

            background-color: white !important;
        }

        /* AVAILABLE */
        td.slot-AVAILABLE {
            background-color: #ffffff !important;
            color: #000;
        }

        /* PAST */
        td.slot-PAST {
            background-color: #e0e0e0 !important;
            color: #777;
        }

        /* BOOKED (PENDING + PAID) */
        td.slot-PENDING,
        td.slot-PAID {
            background-color: #f8d7da !important;
            /* red */
            color: #721c24;
            font-weight: 600;
        }

        /* CANCELLED */
        td.slot-CANCELLED {
            background-color: #ffffff !important;
            color: #000;
        }
    </style>
</head>

<body class="sb-nav-fixed">
    <%- include('../layout/header'); -%>

        <div id="layoutSidenav">
            <%- include('../layout/sidenav'); -%>

                <div id="layoutSidenav_content">
                    <main>
                        <div class="container-fluid px-4">

                            <h1 class="mt-4">Booking Management</h1>
                            <ol class="breadcrumb mb-4">
                                <li class="breadcrumb-item"><a href="/admin">Dashboard</a></li>
                                <li class="breadcrumb-item active">Bookings</li>
                            </ol>

                            <!-- DATE FILTER -->
                            <div class="card mb-4">
                                <div class="card-body">
                                    <form method="get" action="/admin/booking" class="row g-3 align-items-center">

                                        <div class="col-auto">
                                            <button type="button" class="btn btn-outline-primary"
                                                onclick="changeDate(-1)">
                                                <i class="fas fa-chevron-left"></i>
                                            </button>
                                        </div>

                                        <div class="col-auto">
                                            <label class="fw-bold">Date:</label>
                                        </div>

                                        <div class="col-auto">
                                            <input id="bookingDate" type="date" name="date" value="<%= date %>"
                                                class="form-control" />
                                        </div>

                                        <div class="col-auto">
                                            <button class="btn btn-primary">
                                                <i class="fas fa-search"></i> Load
                                            </button>
                                        </div>

                                        <div class="col-auto">
                                            <button type="button" class="btn btn-outline-primary"
                                                onclick="changeDate(1)">
                                                <i class="fas fa-chevron-right"></i>
                                            </button>
                                        </div>

                                    </form>
                                </div>
                            </div>


                            <!-- GRID -->
                            <div class="card mb-4">
                                <div class="card-header">
                                    <i class="fas fa-calendar-alt me-1"></i>
                                    Booking Grid
                                </div>

                                <div class="card-body booking-grid">
                                    <table class="table table-bordered">
                                        <thead>
                                            <tr>
                                                <th>Court / Time</th>
                                                <% if (grid.length> 0) { %>
                                                    <% grid[0].slots.forEach(slot=> { %>
                                                        <th>
                                                            <%= slot.time %>
                                                        </th>
                                                        <% }) %>
                                                            <% } %>
                                            </tr>
                                        </thead>

                                        <tbody>
                                            <% grid.forEach(court=> { %>
                                                <tr>
                                                    <th>
                                                        <%= court.courtName %>
                                                    </th>

                                                    <% court.slots.forEach(slot=> { %>
                                                        <td class="slot slot-<%= slot.status %>">
                                                            <a href="/admin/booking/detail?courtId=<%= court.courtId %>&date=<%= date %>&time=<%= slot.time %>"
                                                                style="display:block; width:100%; height:100%; text-decoration:none; color:inherit;">

                                                                <% if (slot.status==="AVAILABLE" ) { %>
                                                                    AVAIL
                                                                    <% } else if (slot.status==="PAST" ) { %>
                                                                        PAST
                                                                        <% } else { %>
                                                                            <strong>
                                                                                <%= slot.user?.name %>
                                                                            </strong><br />
                                                                            <small>
                                                                                <%= new Intl.NumberFormat('vi-VN', {
                                                                                    style: 'currency' , currency: 'VND'
                                                                                    }).format(slot.price) %>
                                                                            </small>
                                                                            <% } %>

                                                            </a>
                                                        </td>

                                                        <% }) %>
                                                </tr>
                                                <% }) %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                        </div>
                    </main>

                    <%- include('../layout/footer'); -%>
                </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"
            crossorigin="anonymous"></script>
        <script src="/admin/js/scripts.js"></script>
        <script>
            function changeDate(delta) {
                const input = document.getElementById("bookingDate");
                const current = new Date(input.value);

                current.setDate(current.getDate() + delta);

                const yyyy = current.getFullYear();
                const mm = String(current.getMonth() + 1).padStart(2, "0");
                const dd = String(current.getDate()).padStart(2, "0");

                const newDate = `${yyyy}-${mm}-${dd}`;

                window.location.href = `/admin/booking?date=${newDate}`;
            }
        </script>


</body>

</html>